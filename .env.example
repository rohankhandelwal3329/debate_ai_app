# Put this file in the project root (next to run.py), not inside backend/
# Deepgram API Key (for STT and TTS)
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Google Gemini API Key (for LLM) — must be named exactly GEMINI_API_KEY
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: model id (default gemini-2.5-flash). Fallback if quota issues: gemini-1.5-flash
# GEMINI_MODEL=gemini-2.5-flash

# Optional: Server port (defaults to 8000)
# PORT=8000

# Optional: Debug mode (defaults to false)
# DEBUG=false
