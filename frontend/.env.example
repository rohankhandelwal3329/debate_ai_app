# When using `next dev` on :3000 while API runs on :8000:
# NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000
# NEXT_PUBLIC_WS_ORIGIN=ws://127.0.0.1:8000
#
# When opening the app via FastAPI (same origin), leave unset.

# Landing form dev prefill (on by default). For production builds:
# NEXT_PUBLIC_DEV_PREFILL=false
